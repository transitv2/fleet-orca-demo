<h1 class="page-title">Past Processes</h1>

<a href="/bulk-actions" class="btn" style="margin-bottom:16px;display:inline-block;">&larr; Back to Bulk Actions</a>

<div class="table-container">
  <table>
    <thead>
      <tr>
        <th>Job ID</th>
        <th>Type</th>
        <th>File Name</th>
        <th>Card Count</th>
        <th>Status</th>
        <th>Submitted</th>
        <th>Completed</th>
      </tr>
    </thead>
    <tbody>
      <% if (jobs.length === 0) { %>
        <tr><td colspan="7" style="text-align:center;color:#666;">No processes yet.</td></tr>
      <% } else { %>
        <% jobs.forEach(function(job) { %>
          <tr>
            <td><%= job.id %></td>
            <td><%= job.job_type %></td>
            <td><%= job.file_name || '—' %></td>
            <td><%= job.card_count || 0 %></td>
            <td><span class="badge badge-<%= job.status.toLowerCase() %>"><%= job.status %></span></td>
            <td><%= job.submitted_at ? new Date(job.submitted_at).toLocaleString() : '' %></td>
            <td><%= job.completed_at ? new Date(job.completed_at).toLocaleString() : '' %></td>
          </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>
</div>
