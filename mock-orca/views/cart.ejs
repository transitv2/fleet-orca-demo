<h1 class="page-title">Shopping cart</h1>

<% if (typeof notice !== 'undefined' && notice) { %>
  <div class="notice"><%= notice %></div>
<% } %>

<div class="notice">Credit card payments are capped at $10,000 per transaction.</div>

<% if (!cartItems || cartItems.length === 0) { %>
  <p style="color:#666;margin-top:20px;">Your cart is empty.</p>
<% } else { %>
  <form method="POST" action="/cart/checkout">
    <div style="margin-bottom:16px;">
      <label><input type="checkbox" name="pretax" value="1"> Mark as pre-tax</label>
    </div>

    <h3 style="margin-bottom:12px;">Your order</h3>
    <% cartItems.forEach(function(item, i) { %>
      <div class="cart-item">
        <div class="cart-item-header">
          <strong><%= item.description %></strong>
          <span>$<%= item.total.toFixed(2) %></span>
        </div>
        <% if (item.products && item.products.length) { %>
          <ul style="margin-left:20px;font-size:13px;color:#666;">
            <% item.products.forEach(function(p) { %>
              <li><%= p %></li>
            <% }); %>
          </ul>
        <% } %>
      </div>
    <% }); %>

    <div class="cart-total">
      Total: $<%= cartTotal.toFixed(2) %>
    </div>

    <div style="margin-top:20px;">
      <h3 style="margin-bottom:12px;">Shipping address</h3>
      <p style="font-size:14px;color:#666;">Acme Corp<br>100 Main Street, Suite 400<br>Seattle, WA 98101</p>
    </div>

    <div style="margin-top:20px;">
      <h3 style="margin-bottom:12px;">Payment method</h3>
      <div class="form-group">
        <label><input type="radio" name="payment_method" value="Credit Card" checked> Credit Card</label>
      </div>
      <div class="form-group">
        <label><input type="radio" name="payment_method" value="Invoice"> Invoice</label>
      </div>
      <div class="form-group" style="margin-left:24px;">
        <select name="credit_card">
          <option>Test Visa xxxxxxxxxxxx6018</option>
        </select>
      </div>
    </div>

    <button type="submit" class="btn btn-primary" style="margin-top:20px;">PLACE ORDER</button>
  </form>
<% } %>
