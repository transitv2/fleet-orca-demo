<h1 class="page-title">Order history</h1>

<div class="filter-bar">
  <select id="filter-month">
    <option value="">All months</option>
    <% for(let m=1;m<=12;m++){ %>
      <option value="<%= m %>"><%= ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][m-1] %></option>
    <% } %>
  </select>
  <select id="filter-year">
    <option value="">All years</option>
    <option value="2026" selected>2026</option>
    <option value="2025">2025</option>
  </select>
</div>

<div class="table-container">
  <table>
    <thead>
      <tr>
        <th></th>
        <th>Receipt Reference</th>
        <th>Order Date</th>
        <th>Order Total</th>
      </tr>
    </thead>
    <tbody>
      <% orders.forEach(function(order) { %>
        <tr>
          <td><button class="expand-btn" onclick="toggleExpand('<%= order.id %>')">&#9654;</button></td>
          <td><%= order.order_number %></td>
          <td><%= new Date(order.order_date).toLocaleDateString() %></td>
          <td>$<%= parseFloat(order.total_amount).toFixed(2) %></td>
        </tr>
        <tr id="expand-<%= order.id %>" class="expand-content">
          <td colspan="4">
            <div class="order-meta-grid" style="margin-bottom:12px;">
              <div class="order-meta-item"><label>Order Number</label><span><%= order.order_number %></span></div>
              <div class="order-meta-item"><label>Status</label><span><%= order.status %></span></div>
              <div class="order-meta-item"><label>Payment</label><span><%= order.payment_method %></span></div>
              <div class="order-meta-item"><label>Quantity</label><span><%= order.quantity %></span></div>
            </div>
            <a href="/order-history/<%= order.id %>" class="btn btn-sm">View order details</a>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<script>
function toggleExpand(id) {
  const row = document.getElementById('expand-' + id);
  row.classList.toggle('open');
  row.style.display = row.classList.contains('open') ? 'table-row' : 'none';
}
</script>
